# Telegram (required)
# 1. Create a bot via @BotFather → paste token below
# 2. Start the bot, send /start, check logs for "message from chat_id=..."
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Personal info used in the booking form (required)
# The API only has one name field — put your full name here (e.g. "Rohit Misra")
FAMILY_NAME=
EMAIL=
TELEPHONE=

# Target — Verpflichtungserklärung at KVR Schnellschalter (override if needed)
SERVICE_ID=1063741
OFFICE_ID=10308621

# Polling
POLL_SECONDS=45
LOOK_AHEAD_DAYS=90

# State file location (local dev: ./data, Docker: /app/data via compose)
STATE_DIR=./data
